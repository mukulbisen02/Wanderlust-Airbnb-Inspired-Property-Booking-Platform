<% layout("layouts/boilerplate") %>
<body>
    <h3>Listong Details :</h3>
    <ul>
        <li>Title: <%= listing.title %></li>
        <li>Description: <%= listing.description %></li>
        <!-- <li>Price: $<%= listing.price %></li> -->
        <li>Price: &#8377;<%= listing.price.toLocaleString("en-IN") %></li>
        <li>Location: <%= listing.location %></li>
        <li>Country: <%= listing.country %></li>
    </ul>
    <br>
    <a href="/listings/<%= listing._id %>/edit">Edit this Listing</a>
    <br><br>

    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
        <button type="submit">Delete this Listing</button>
    </form>
</body>